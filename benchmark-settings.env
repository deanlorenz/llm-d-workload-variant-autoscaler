#!/usr/bin/env bash
# benchmark-settings.env — WVA-vs-KEDA Scenario 1 configuration
#
# Usage:
#   export HF_TOKEN="hf_..."          # set first — not stored here
#   source benchmark-settings.env

: "${HF_TOKEN:?Set HF_TOKEN before sourcing this file (export HF_TOKEN=hf_...)}"

# ── Cluster / Namespace ───────────────────────────────────────────────────────
# Which namespace to create for the benchmark deployments.
export BENCHMARK_NS="llmd-bench"

# ── Model ─────────────────────────────────────────────────────────────────────
# HF_MODEL_ID: HuggingFace repository used to pull the model weights.
# SERVED_MODEL_ID: the name vLLM advertises in the OpenAI API (--served-model-name).
#   If not set explicitly, vLLM defaults to the HF model path, so they can be the same.
#   GuideLLM and WVA VA resources must both use the SERVED_MODEL_ID.
export HF_MODEL_ID="meta-llama/Llama-3.1-8B-Instruct"
export SERVED_MODEL_ID="meta-llama/Llama-3.1-8B-Instruct"   # matches WVA modelID and GuideLLM --model

# ── Variants ──────────────────────────────────────────────────────────────────
# Two logical variants A (cheap) and B (expensive).
# For heterogeneous clusters: set different GPU labels.
# For homogeneous clusters: set the same GPU label; cost difference models org tiering.

# Variant A — cheap tier
export VARIANT_A_NAME="variant-a"                # used as VA name and deployment name suffix
export VARIANT_A_GPU_LABEL="NVIDIA-L40-48GB"     # nvidia.com/gpu.product label on target nodes
export VARIANT_A_COST=15
export VARIANT_A_MAX_REPLICAS=2

# Variant B — expensive tier
export VARIANT_B_NAME="variant-b"
export VARIANT_B_GPU_LABEL="NVIDIA-H100-80GB-SXM5"
export VARIANT_B_COST=65
export VARIANT_B_MAX_REPLICAS=3

# Derived deployment names (no need to change these)
export VARIANT_A_DEPLOY="ms-bench-${VARIANT_A_NAME}"
export VARIANT_B_DEPLOY="ms-bench-${VARIANT_B_NAME}"

# ── Versions (must match your cluster) ────────────────────────────────────────
export LLM_D_RELEASE="v0.7.0"         # llm-d stack version
export BENCHMARK_REPO_REF="v0.6.0"    # llm-d-benchmark CLI version

# ── Well-known namespaces (change only if you customised the WVA install) ─────
export WVA_NS="workload-variant-autoscaler-system"
export PROM_NS="workload-variant-autoscaler-monitoring"
